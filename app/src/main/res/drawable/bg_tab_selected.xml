<?xml version="1.0" encoding="utf-8"?>
<!--
    res/drawable/bg_tab_selected.xml
    Dipakai di: tombol jenis dompet (dialog_tambah_dompet.xml)
    dan tab DOMPET/HUTANG (fragment_dompet.xml via Button).

    PENTING: Jika bg_tab_selected.xml yang sudah ada di project-mu
    TIDAK punya state_selected, ganti isinya dengan file ini.
    Jika sudah ada dan sudah berfungsi, tidak perlu diubah.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Terpilih: background biru navy muda dengan stroke -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="#E8EDF7" />
            <stroke android:width="2dp" android:color="#2C3E6B" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F5F5F5" />
            <stroke android:width="1dp" android:color="#E0E0E0" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>