<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="3dp"
        android:background="#CCCCCC"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"/>

    <!-- Header: tutup (X) di kanan -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnTutupDetail"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="#888888"
            android:layout_gravity="end|center_vertical"
            android:contentDescription="Tutup"/>
    </FrameLayout>

    <!-- Info tabungan: nama + tombol hapus -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_paper_bag"
            android:background="@drawable/bg_circle_blue"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Target"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:id="@+id/tvDetailHariIni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hari ini: -"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnHapusTabungan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="HAPUS"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E53935"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
    </LinearLayout>

    <!-- Nominal terkumpul + sisa -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TERKUMPUL"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvDetailTerkumpul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SISA"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvDetailSisa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E53935"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── RIWAYAT CICILAN — di atas input nominal seperti referensi ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Riwayat cicilan"
        android:textSize="13sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRiwayatTabungan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp"
        android:nestedScrollingEnabled="false"
        android:clipToPadding="false"/>

    <!-- ── Label input nominal ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MASUKKAN NOMINAL TABUNGAN"
        android:textSize="11sp"
        android:textColor="#888888"
        android:letterSpacing="0.08"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <!-- Input nominal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etNominalTabung"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="0"
            android:inputType="number"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:background="@null"
            android:gravity="center"/>
    </LinearLayout>

    <!-- ── Tanggal bayar ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tanggal bayar"
        android:textSize="13sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="6dp"/>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTanggalTabung"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:clickable="true"
            android:textSize="14sp"
            android:textColor="#1A2B34"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- ── Sumber Dana dropdown ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sumber Dana"
        android:textSize="13sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="6dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@android:color/white"
        app:strokeColor="#CCCCCC"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/llSumberDanaHeader"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivIkonDompetDipilih"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="12dp"
                    android:scaleType="fitCenter"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvSumberDanaTabungan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pilih dompet..."
                    android:textSize="14sp"
                    android:textColor="#888888"/>

                <ImageView
                    android:id="@+id/ivChevronSumberDanaTabungan"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_down"
                    android:scaleType="fitCenter"/>

            </LinearLayout>

            <View
                android:id="@+id/dividerSumberDanaTabungan"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/llOpsiDompetTabungan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── Tombol Konfirmasi ── -->
    <Button
        android:id="@+id/btnKonfirmasiTabung"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:text="KONFIRMASI"
        android:backgroundTint="#2C3E6B"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"/>

    <!-- ── Switch prioritas ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="#FFF9E6">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Jadikan Sebagai Target Tabungan Prioritas?"
            android:textSize="12sp"
            android:textColor="#555555"/>

        <Switch
            android:id="@+id/switchPrioritas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>