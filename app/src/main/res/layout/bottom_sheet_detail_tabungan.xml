<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:paddingBottom="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="3dp"
        android:background="#CCCCCC"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"/>

    <!-- Header: tutup (X) di kanan -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnTutupDetail"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:tint="#888888"
            android:layout_gravity="end|center_vertical"
            android:contentDescription="Tutup"/>
    </FrameLayout>

    <!-- Info tabungan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="16dp">

        <!-- Ikon placeholder -->
        <View
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle_pink"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Target"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"/>

            <TextView
                android:id="@+id/tvDetailHariIni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hari ini: -"
                android:textSize="12sp"
                android:textColor="#888888"/>
        </LinearLayout>

        <!-- Edit + Hapus -->
        <ImageButton
            android:id="@+id/btnEditTabungan"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle_blue_light"
            android:src="@drawable/ic_edit"
            android:tint="#4A6FA5"
            android:padding="8dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="Edit"/>

        <ImageButton
            android:id="@+id/btnHapusTabungan"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle_red_light"
            android:src="@drawable/ic_delete"
            android:tint="#E53935"
            android:padding="8dp"
            android:contentDescription="Hapus"/>
    </LinearLayout>

    <!-- Terkumpul -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TERKUMPUL"
            android:textSize="11sp"
            android:textColor="#888888"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/tvDetailTerkumpul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"/>
    </LinearLayout>

    <!-- Input nominal -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MASUKKAN NOMINAL TABUNGAN"
        android:textSize="11sp"
        android:textColor="#888888"
        android:letterSpacing="0.08"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F5"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etNominalTabung"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="0"
            android:inputType="number"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:background="@null"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Tombol pilih dompet + konfirmasi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnPilihDompet"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="PILIH DOMPET"
            android:backgroundTint="#FFB6C1"
            android:textColor="#1A1A2E"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnKonfirmasiTabung"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="KONFIRMASI"
            android:backgroundTint="#2C3E6B"
            android:textColor="@android:color/white"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Switch prioritas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#FFF9E6"
        android:padding="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Jadikan Sebagai Target Tabungan Prioritas?"
            android:textSize="12sp"
            android:textColor="#555555"/>

        <Switch
            android:id="@+id/switchPrioritas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>