<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="3dp"
        android:background="#CCCCCC"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"/>

    <!-- Header: tutup (X) di kanan -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/btnTutupDetail"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="@color/text_secondary"
            android:layout_gravity="end|center_vertical"
            android:contentDescription="Tutup"/>
    </FrameLayout>

    <!-- Info tabungan: nama + tombol hapus -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_paper_bag"
            android:background="@drawable/bg_circle_blue"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:layout_marginEnd="14dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Target"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvDetailHariIni"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hari ini: -"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnHapusTabungan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/hapus"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E53935"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
    </LinearLayout>

    <!-- Nominal terkumpul + sisa -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_tabungan_tercapai"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvDetailTerkumpul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_kurang"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvDetailSisa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#E53935"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── RIWAYAT CICILAN ── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_riwayat_cicilan"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRiwayatTabungan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp"
        android:nestedScrollingEnabled="false"
        android:clipToPadding="false"/>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- FITUR BARU: Tombol "Saya Sudah Membeli Impian Ini"                   -->
    <!--                                                                       -->
    <!-- Hanya tampil saat:                                                    -->
    <!--   - terkumpul >= targetNominal (target selesai 100%)                 -->
    <!--   - sudahDigunakan = false (belum pernah dikonfirmasi)               -->
    <!--                                                                       -->
    <!-- Visibility diatur dari DetailTabunganBottomSheet.kt,                  -->
    <!-- default GONE agar tidak muncul sebelum kondisi diperiksa.            -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <Button
        android:id="@+id/btnSudahMembeli"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:text="✓ Saya Sudah Membeli Impian Ini"
        android:backgroundTint="#4CAF50"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!-- Form input — disembunyikan saat target SELESAI                       -->
    <!-- Setiap blok diberi id group container agar bisa toggle visibility    -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->

    <!-- Label input nominal -->
    <TextView
        android:id="@+id/labelNominalTabungan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_nominal_cicilan"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:letterSpacing="0.08"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="8dp"/>

    <!-- Input nominal -->
    <LinearLayout
        android:id="@+id/containerNominalTabungan"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#4F6B88"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etNominalTabung"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="0"
            android:inputType="number"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@null"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Label tanggal -->
    <TextView
        android:id="@+id/labelTanggalTabungan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_tanggal_bayar"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="6dp"/>

    <!-- Input tanggal -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/containerTanggalTabungan"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        app:boxBackgroundColor="#4F6B88"
        app:boxStrokeColor="#6E89A5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etTanggalTabung"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:focusable="false"
            android:clickable="true"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Label sumber dana -->
    <TextView
        android:id="@+id/labelSumberDana"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_sumber_dana"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="6dp"/>

    <!-- Dropdown sumber dana -->
    <androidx.cardview.widget.CardView
        android:id="@+id/containerSumberDana"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#4F6B88"
        app:strokeColor="#6E89A5"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/llSumberDanaHeader"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ivIkonDompetDipilih"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="12dp"
                    android:scaleType="fitCenter"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvSumberDanaTabungan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pilih dompet..."
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"/>

                <ImageView
                    android:id="@+id/ivChevronSumberDanaTabungan"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    app:tint="@color/text_primary"
                    android:src="@drawable/ic_chevron_down"
                    android:scaleType="fitCenter"/>

            </LinearLayout>

            <View
                android:id="@+id/dividerSumberDanaTabungan"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#6E89A5"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/llOpsiDompetTabungan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tombol Konfirmasi (mode BERJALAN) -->
    <Button
        android:id="@+id/btnKonfirmasiTabung"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_selesai"
        android:backgroundTint="#56789A"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"/>

    <!-- Switch prioritas (mode BERJALAN) -->
    <LinearLayout
        android:id="@+id/containerPrioritas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/bg_card">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/toast_prioritas_diset"
            android:textSize="12sp"
            android:textColor="@color/text_primary"/>

        <Switch
            android:id="@+id/switchPrioritas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>