<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8E4DC"
    android:orientation="vertical">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#6B8FA3"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <!-- Title Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:tint="@color/white"
                android:contentDescription="Kembali" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="DOMPETKU"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </RelativeLayout>

        <!-- Kartu Ringkasan Saldo -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saldo Bersih"
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_total_saldo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textColor="#2C3E50"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Semua Dompet"
                    android:textColor="#888888"
                    android:textSize="11sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#EEEEEE" />

                <!-- Stats Row: Terbesar + Dompet Aktif -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Terbesar"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_dompet_terbesar"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#2C3E50"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dompet Aktif"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tv_dompet_aktif"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#2C3E50"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- ===== BANNER INFO HUTANG =====
         Hanya muncul jika ada hutang aktif (visibility diatur dari Fragment).
         Kalau tidak ada hutang, layout ini di-GONE.
    -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_info_hutang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFF8F6"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- Stripe merah kiri -->
            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#C62828"
                android:layout_marginEnd="12dp" />

            <!-- Teks info hutang -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Hutang Aktif"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#C62828" />

                <TextView
                    android:id="@+id/tv_info_hutang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 hutang · Total Rp 1.500.000"
                    android:textSize="12sp"
                    android:textColor="#546E7A"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Tombol lihat detail -->
            <TextView
                android:id="@+id/tv_lihat_hutang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lihat »"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#2C3E6B"
                android:paddingStart="8dp"
                android:paddingEnd="4dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ===== BARIS JUDUL + TAMBAH ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E8E4DC"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DOMPET"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#2C3E6B"
            android:letterSpacing="0.08" />

        <Button
            android:id="@+id/btn_tambah_dompet"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="+ Tambah"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:backgroundTint="#2C3E6B"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

    <!-- ===== DAFTAR DOMPET ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_dompet"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="88dp" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layout_empty_dompet"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:paddingBottom="80dp">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_wallet"
            android:alpha="0.3"
            android:contentDescription="Belum ada dompet" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belum ada dompet"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#546E7A"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tambah dompet pertamamu sekarang!"
            android:textSize="13sp"
            android:textColor="#90A4AE"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>