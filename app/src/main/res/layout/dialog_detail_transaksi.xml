<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:paddingBottom="20dp">

    <!-- ── Toolbar: X  |  [spacer]  |  Delete  Edit ── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:paddingHorizontal="12dp">

        <!-- Tombol X (tutup) -->
        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            app:tint="@color/text_secondary"/>

        <!-- Tombol Edit -->
        <ImageView
            android:id="@+id/btn_edit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_edit"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            app:tint="#4A6FA5"/>

        <!-- Tombol Hapus -->
        <ImageView
            android:id="@+id/btn_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_delete"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btn_edit"
            android:layout_marginEnd="4dp"
            app:tint="#C62828"/>

    </RelativeLayout>

    <!-- ── Card isi konten ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="20dp"
        android:background="@drawable/bg_dialog_card"
        android:padding="20dp">

        <!-- Baris atas: ikon + nominal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/iv_dialog_icon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="4dp"
                tools:src="@drawable/ic_wallet"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tv_dialog_kategori"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    tools:text="Makanan"/>

                <TextView
                    android:id="@+id/tv_dialog_nominal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    tools:text="+Rp 70.000"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="14dp"/>

        <!-- Tanggal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_tanggal_detail"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_dialog_tanggal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="5 Mei 2026"/>
        </LinearLayout>

        <!-- Dompet / Sumber Dana — tampil untuk PEMASUKAN & PENGELUARAN -->
        <LinearLayout
            android:id="@+id/row_dompet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_dompet_detail"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_dialog_dompet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Bank BCA"/>
        </LinearLayout>

        <!-- Dari Dompet — khusus TRANSFER -->
        <LinearLayout
            android:id="@+id/row_dari_dompet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:visibility="gone">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_dari_detail"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_dialog_dari_dompet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Gopay"/>
        </LinearLayout>

        <!-- Ke Dompet — khusus TRANSFER -->
        <LinearLayout
            android:id="@+id/row_ke_dompet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:visibility="gone">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_ke_detail"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_dialog_ke_dompet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                tools:text="Tunai"/>
        </LinearLayout>

        <!-- Catatan — hanya tampil untuk PEMASUKAN & PENGELUARAN -->
        <LinearLayout
            android:id="@+id/row_catatan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_catatan_detail"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tv_dialog_catatan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                tools:text="Makan siang bersama tim"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>