<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E2E2E2">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="80dp">

        <!-- Avatar pojok kanan -->
        <ImageView
            android:id="@+id/iv_avatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="20dp"
            android:src="@drawable/logo_moneego"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Judul -->
        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:text="MoneeGo!"
            android:textColor="#1A1A2E"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Card Saldo -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_saldo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#B0BEC5"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/tv_greeting"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_label_saldo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_saldo"
                    android:textSize="13sp"
                    android:textColor="#4A4A4A"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <ImageView
                    android:id="@+id/iv_toggle_saldo"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_eye"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintTop_toTopOf="@id/tv_label_saldo"
                    app:layout_constraintBottom_toBottomOf="@id/tv_label_saldo"
                    app:layout_constraintStart_toEndOf="@id/tv_label_saldo"/>

                <TextView
                    android:id="@+id/tv_saldo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_label_saldo"
                    app:layout_constraintStart_toStartOf="parent"/>

                <LinearLayout
                    android:id="@+id/ll_nav_bulan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_saldo"
                    app:layout_constraintStart_toStartOf="parent">

                    <TextView
                        android:id="@+id/btn_prev_bulan"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="◀"
                        android:textSize="14sp"
                        android:textColor="#4A4A4A"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/tv_bulan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Januari 2026"
                        android:textSize="12sp"
                        android:textColor="#4A4A4A"
                        android:paddingHorizontal="4dp"/>

                    <TextView
                        android:id="@+id/btn_next_bulan"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="▶"
                        android:textSize="14sp"
                        android:textColor="#4A4A4A"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_ringkasan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/ll_nav_bulan"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_pemasukan"
                            android:textSize="11sp"
                            android:textColor="#4A4A4A"/>
                        <TextView
                            android:id="@+id/tv_pemasukan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_pengeluaran"
                            android:textSize="11sp"
                            android:textColor="#4A4A4A"/>
                        <TextView
                            android:id="@+id/tv_pengeluaran"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#F44336"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selisih"
                            android:textSize="11sp"
                            android:textColor="#4A4A4A"/>
                        <TextView
                            android:id="@+id/tv_selisih"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp0"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- Menu Shortcut: Dompet, Tabungan, Hutang -->
        <LinearLayout
            android:id="@+id/ll_menu_shortcut"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/card_saldo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/btn_dompet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_white_rounded"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_dompet_menu"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/menu_dompet"
                    android:textSize="12sp"
                    android:textColor="#4A4A4A"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_tabungan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_white_rounded"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_tabungan_menu" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/menu_tabungan"
                    android:textSize="12sp"
                    android:textColor="#4A4A4A"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_hutang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card_white_rounded"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_hutang_menu"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/menu_hutang"
                    android:textSize="12sp"
                    android:textColor="#4A4A4A"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Card Banner Tabungan -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_banner_tabungan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#B0BEC5"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/ll_menu_shortcut"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_banner_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/banner_title"
                    android:textColor="#1A1A2E"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_banner_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/banner_desc"
                    android:textColor="#4A4A4A"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_buat_target"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="#4A6FA5"
                    android:text="@string/btn_buat_target"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!--
        ══════════════════════════════════════════════════════════════════════
        CARD INSIGHT — container besar dengan judul + dua card anak
        PERUBAHAN:
          - padding container dikurangi: 20dp → 14dp
          - marginBottom judul dikurangi: 12dp → 8dp
          - tinggi card anak: 130dp → 110dp (lebih proporsional, tidak terlalu tinggi)
          - gap antar card dikurangi: marginEnd 8dp → 6dp
          - padding dalam card anak: 12dp → 10dp
        ══════════════════════════════════════════════════════════════════════
        -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_insight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#B0BEC5"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/card_banner_tabungan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Judul section INSIGHT ANDA — tetap dipertahankan -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_insight"
                    android:textColor="#1A1A2E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp"/>

                <!-- Row dua card anak — lebih rapat, lebih lebar, lebih pendek -->
                <LinearLayout
                    android:id="@+id/ll_insight_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- ── Card 1: Ringkasan / Selamat Datang ─────────────── -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_ringkasan"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFCDD2">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <!-- Indikator lingkaran merah + judul -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <View
                                    android:id="@+id/view_indikator_ringkasan"
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:background="@drawable/bg_circle_red"
                                    android:layout_marginEnd="6dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/insight1_title"
                                    android:textColor="#1A1A2E"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Isi insight -->
                            <TextView
                                android:id="@+id/tv_insight_ringkasan"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginTop="6dp"
                                android:text="Memuat..."
                                android:textColor="#4A4A4A"
                                android:textSize="10sp"
                                android:lineSpacingMultiplier="1.3"
                                android:maxLines="4"
                                android:ellipsize="end"
                                android:gravity="top"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ── Card 2: Tips MoneeGo ───────────────────────────── -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_tips"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFF9C4">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <!-- Indikator lingkaran kuning + judul -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="10dp"
                                    android:background="@drawable/bg_circle_yellow"
                                    android:layout_marginEnd="6dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/insight2_title"
                                    android:textColor="#1A1A2E"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- Isi tips -->
                            <TextView
                                android:id="@+id/tv_insight_tips"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:layout_marginTop="6dp"
                                android:text="Memuat..."
                                android:textColor="#4A4A4A"
                                android:textSize="10sp"
                                android:lineSpacingMultiplier="1.3"
                                android:maxLines="4"
                                android:ellipsize="end"
                                android:gravity="top"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>