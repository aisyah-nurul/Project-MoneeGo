<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Icon bulat kiri -->
        <ImageView
            android:id="@+id/iv_ikon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_pink"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Nama tabungan -->
        <TextView
            android:id="@+id/tv_nama_tabungan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nama Target"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/iv_ikon"
            app:layout_constraintStart_toEndOf="@id/iv_ikon"
            app:layout_constraintEnd_toStartOf="@id/tv_target_label"/>

        <!-- Deadline -->
        <TextView
            android:id="@+id/tv_deadline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Deadline: -"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toBottomOf="@id/tv_nama_tabungan"
            app:layout_constraintStart_toEndOf="@id/iv_ikon"
            app:layout_constraintEnd_toStartOf="@id/tv_target_label"/>

        <!-- Label TARGET kanan atas -->
        <TextView
            android:id="@+id/tv_target_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TARGET"
            android:textSize="10sp"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Nominal target -->
        <TextView
            android:id="@+id/tv_target_nominal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintTop_toBottomOf="@id/tv_target_label"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Divider tipis -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/iv_ikon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Label TERKUMPUL -->
        <TextView
            android:id="@+id/tv_label_terkumpul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TERKUMPUL"
            android:textSize="10sp"
            android:letterSpacing="0.08"
            android:textColor="@color/text_hint"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Nominal terkumpul -->
        <TextView
            android:id="@+id/tv_terkumpul"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Rp0"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tv_label_terkumpul"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_persentase"/>

        <!-- Persentase kanan -->
        <TextView
            android:id="@+id/tv_persentase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0%"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintBaseline_toBaselineOf="@id/tv_terkumpul"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progress_tabungan"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:progress="0"
            android:progressTint="#4A6FA5"
            android:progressBackgroundTint="@color/progress_track"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_terkumpul"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Sisa kiri bawah -->
        <TextView
            android:id="@+id/tv_sisa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="⏰ Kurang Rp0"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/progress_tabungan"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_tabung"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Tombol Tabung kanan bawah -->
        <Button
            android:id="@+id/btn_tabung"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="Tabung ↗"
            android:textSize="11sp"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/card_shortcut_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toTopOf="@id/tv_sisa"
            app:layout_constraintBottom_toBottomOf="@id/tv_sisa"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>