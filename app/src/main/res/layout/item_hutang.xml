<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <View
            android:id="@+id/view_garis"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#F44336"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <TextView
                android:id="@+id/tv_nama_hutang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Nama"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_selesai"/>

            <LinearLayout
                android:id="@+id/ll_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tv_nama_hutang"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_selesai">

                <TextView
                    android:id="@+id/tv_nominal_hutang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  •  "
                    android:textColor="#888888"/>

                <TextView
                    android:id="@+id/tv_tanggal_hutang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_catatan_hutang"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Catatan"
                android:textSize="13sp"
                android:textColor="#4A4A4A"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/ll_info"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_selesai"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <Button
                android:id="@+id/btn_selesai"
                android:layout_width="80dp"
                android:layout_height="36dp"
                android:text="Selesai"
                android:textSize="12sp"
                android:backgroundTint="#4A6FA5"
                android:textColor="@android:color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>