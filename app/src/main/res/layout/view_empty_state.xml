<?xml version="1.0" encoding="utf-8"?>
<!-- Reusable empty state — include di mana saja dengan:
     <include layout="@layout/view_empty_state" android:id="@+id/layout_empty" ... />
     Lalu set android:visibility="gone" di parent include-nya.
     Ganti teks via tvEmptyLabel di Fragment/Activity masing-masing.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_empty"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:visibility="gone">

    <ImageView
        android:id="@+id/iv_empty"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:alpha="0.35"
        android:contentDescription="Tidak ada data"/>

    <TextView
        android:id="@+id/tv_empty_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/teks_muted"
        android:textSize="13sp"
        android:layout_marginTop="8dp"/>

</LinearLayout>