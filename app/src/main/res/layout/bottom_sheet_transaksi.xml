<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_card"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:background="@color/progress_track" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/ivBottomIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_circle_gray"
            android:padding="7dp"
            android:src="@drawable/ic_kategori"
            app:tint="@color/primary_navy"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBottomKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Makanan"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvBottomBulan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mei 2026"
                android:textSize="11sp"
                android:textColor="@color/text_hint" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvBottomTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rp 0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark_navy" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="8dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvBottomEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tidak ada transaksi"
        android:textSize="13sp"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone" />

    <!-- List Transaksi -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBottomTransaksi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:nestedScrollingEnabled="false" />

</LinearLayout>