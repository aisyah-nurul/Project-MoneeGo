<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <View
        android:layout_width="36dp"
        android:layout_height="3dp"
        android:background="#CCCCCC"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tambah Target Tabungan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama Target"
        android:textSize="12sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etNamaTabungan"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Contoh: Beli Laptop"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textSize="13sp"
        android:background="@drawable/bg_input_rounded"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Target Nominal"
        android:textSize="12sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etTargetNominal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Rp 0"
        android:inputType="number"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textSize="13sp"
        android:background="@drawable/bg_input_rounded"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deadline (Opsional)"
        android:textSize="12sp"
        android:textColor="#555555"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etDeadlineTabungan"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Pilih tanggal"
        android:focusable="false"
        android:clickable="true"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textSize="13sp"
        android:background="@drawable/bg_input_rounded"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnSimpanTabungan"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:text="Simpan Target"
        android:textColor="@android:color/white"
        android:backgroundTint="#2C3E6B"
        android:textSize="13sp"/>

    <Button
        android:id="@+id/btnBatalTabungan"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Batal"
        android:backgroundTint="@android:color/transparent"
        android:textColor="#888888"
        android:textSize="12sp"
        android:elevation="0dp"
        android:layout_marginBottom="8dp"/>

</LinearLayout>