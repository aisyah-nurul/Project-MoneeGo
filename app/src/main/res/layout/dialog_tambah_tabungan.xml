<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tambah Target Tabungan"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama Target"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_nama_tabungan"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Contoh: Beli Laptop"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input_rounded"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Target Nominal"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_target_nominal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Rp 0"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input_rounded"
        android:inputType="numberDecimal"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_simpan_tabungan"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Simpan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#4A6FA5"
        android:textColor="@android:color/white"/>

</LinearLayout>