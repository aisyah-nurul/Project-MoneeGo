<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDE8DC">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TAMBAH TRANSAKSI"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tab Pengeluaran / Pemasukan / Transfer -->
    <LinearLayout
        android:id="@+id/ll_tab_jenis"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tab_pengeluaran"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="PENGELUARAN"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_tab_selected"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tab_pemasukan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="PEMASUKAN"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="@android:color/transparent"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tab_transfer"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Transfer"
            android:textSize="13sp"
            android:textColor="#888888"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:background="@android:color/transparent"/>

    </LinearLayout>

    <!-- Card Form -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_form"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#D6D0C4"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/ll_tab_jenis"
        app:layout_constraintBottom_toTopOf="@id/ll_numpad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Nominal -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NOMINAL (Rp)"
                android:textSize="12sp"
                android:textColor="#888888"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_nominal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Kategori -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_kategori"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_kategori"
                        android:layout_marginEnd="12dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kategori"
                            android:textSize="11sp"
                            android:textColor="#4A6FA5"/>
                        <TextView
                            android:id="@+id/tv_kategori"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Makanan"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_down"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tanggal -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_tanggal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_tanggal"
                        android:layout_marginEnd="12dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tanggal"
                            android:textSize="11sp"
                            android:textColor="#4A6FA5"/>
                        <TextView
                            android:id="@+id/tv_tanggal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hari ini"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_down"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Catatan -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_catatan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_catatan"
                        android:layout_marginEnd="12dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Catatan"
                            android:textSize="11sp"
                            android:textColor="#4A6FA5"/>
                        <TextView
                            android:id="@+id/tv_catatan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tambah catatan..."
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_down"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sumber Dana -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_sumber_dana"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_wallet"
                        android:layout_marginEnd="12dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sumber Dana"
                            android:textSize="11sp"
                            android:textColor="#4A6FA5"/>
                        <TextView
                            android:id="@+id/tv_sumber_dana"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tunai"
                            android:textSize="14sp"
                            android:textColor="#1A1A2E"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_chevron_down"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Numpad -->
    <GridLayout
        android:id="@+id/ll_numpad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Row 1 -->
        <Button android:id="@+id/btn_1" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="1" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_2" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="2" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_3" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="3" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_minus" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="-" android:textSize="22sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>

        <!-- Row 2 -->
        <Button android:id="@+id/btn_4" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="4" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_5" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="5" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_6" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="6" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_enter" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="⏎" android:textSize="22sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>

        <!-- Row 3 -->
        <Button android:id="@+id/btn_7" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="7" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_8" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="8" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_9" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="9" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_hapus" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="⌫" android:textSize="22sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>

        <!-- Row 4 -->
        <Button android:id="@+id/btn_bintang" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="*#" android:textSize="14sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_0" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="0" android:textSize="18sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_plus" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="+" android:textSize="22sp"
            android:backgroundTint="@android:color/transparent" android:textColor="#1A1A2E"/>
        <Button android:id="@+id/btn_simpan" android:layout_width="0dp"
            android:layout_columnWeight="1" android:layout_height="56dp"
            android:text="SIMPAN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:backgroundTint="#4A6FA5"
            android:textColor="@android:color/white"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>