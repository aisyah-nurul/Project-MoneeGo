<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E2E2E2">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#78909C"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="30dp"
        android:paddingBottom="24dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_left"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@android:color/white"
                android:contentDescription="Kembali"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="TABUNGANKU"
                android:textColor="@android:color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
        </RelativeLayout>

        <!-- ── CARD 1: Ringkasan Tabungan ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_total_tabungan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#EDEBEB"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Label + Icon Mata -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_jumlah_impian"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Terkumpul dari 0 Impian"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                    <ImageView
                        android:id="@+id/iv_toggle_saldo_tabungan"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_eye"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Toggle saldo tabungan"/>
                </LinearLayout>

                <!-- Nominal total terkumpul -->
                <TextView
                    android:id="@+id/tv_total_terkumpul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginTop="2dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Stats Row: Berjalan kiri, Tercapai kanan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Berjalan — hitam -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tabungan Berjalan"
                            android:textSize="11sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tv_berjalan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2C3E50"/>
                    </LinearLayout>

                    <!-- Tercapai — hijau -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tabungan Tercapai"
                            android:textSize="11sp"
                            android:textColor="#888888"/>

                        <TextView
                            android:id="@+id/tv_tercapai"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── CARD 2: Motivasi / Insight — terpisah, di bawah card ringkasan ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_insight_tabungan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#EDEBEB"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_info"/>

                <TextView
                    android:id="@+id/tv_insight_tabungan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Semangat menabung untuk mencapai impianmu!"
                    android:textSize="12sp"
                    android:textColor="#1A1A2E"
                    android:layout_marginStart="10dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Banner Hutang Aktif -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_info_hutang"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFF8F6"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <View
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="#C62828"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Hutang Aktif"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#C62828"/>

                <TextView
                    android:id="@+id/tv_info_hutang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 hutang · Total Rp 0"
                    android:textSize="12sp"
                    android:textColor="#546E7A"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_lihat_hutang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lihat »"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#2C3E6B"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tab Berjalan / Selesai -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutTabungan"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/white"
        app:tabIndicatorColor="#6B828D"
        app:tabIndicatorHeight="3dp"
        app:tabRippleColor="@null"
        app:tabSelectedTextColor="#6B828D"
        app:tabTextColor="@color/teks_muted">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_berjalan"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_selesai"/>
    </com.google.android.material.tabs.TabLayout>

    <!-- Tombol Tambah Tabungan -->
    <Button
        android:id="@+id/btn_tambah_tabungan"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:text="+ Tambah tabungan"
        android:textColor="@android:color/white"
        android:backgroundTint="#78909C"
        android:textSize="13sp"
        app:cornerRadius="10dp"/>

    <!-- RecyclerView + Empty State -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_tabungan"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:clipToPadding="false"/>

        <LinearLayout
            android:id="@+id/layout_empty_tabungan"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_hutang"
                android:alpha="0.35"
                android:contentDescription="Belum ada tabungan"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada tabungan"
                android:textColor="@color/teks_muted"
                android:textSize="13sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

    </FrameLayout>

</LinearLayout>