<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDE8DC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_back"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_centerVertical="true"
                    android:contentDescription="Kembali"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TABUNGANKU"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:layout_centerInParent="true"/>
            </RelativeLayout>

            <!-- Card Total Tabungan -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_total_tabungan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#B0BEC5"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MoneeGo!"
                        android:textSize="13sp"
                        android:textColor="#4A4A4A"/>

                    <TextView
                        android:id="@+id/tv_total_terkumpul"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/tv_jumlah_impian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Terkumpul dari 0 Impian"
                        android:textSize="12sp"
                        android:textColor="#4A4A4A"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="10dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_check_green"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Achieved"
                                    android:textSize="12sp"
                                    android:textColor="#4A4A4A"
                                    android:layout_marginStart="4dp"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tv_tercapai"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00 Target"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A2E"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/ic_flash_yellow"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ongoing"
                                    android:textSize="12sp"
                                    android:textColor="#4A4A4A"
                                    android:layout_marginStart="4dp"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tv_berjalan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="00 Target"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A2E"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Banner insight -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_insight_tabungan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="10dp"
                        app:cardBackgroundColor="#E8EAF6">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_info"/>
                            <TextView
                                android:id="@+id/tv_insight_tabungan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Semangat menabung!"
                                android:textSize="12sp"
                                android:textColor="#1A1A2E"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Banner Hutang Aktif -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_info_hutang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF8F6"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="#C62828"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️ Hutang Aktif"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#C62828"/>

                        <TextView
                            android:id="@+id/tv_info_hutang"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1 hutang · Total Rp 0"
                            android:textSize="12sp"
                            android:textColor="#546E7A"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_lihat_hutang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lihat »"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#2C3E6B"
                        android:paddingStart="8dp"
                        android:paddingEnd="4dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tab Berjalan / Selesai -->
            <LinearLayout
                android:id="@+id/ll_tab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btn_tab_berjalan"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="BERJALAN"
                    android:backgroundTint="#2C3E6B"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btn_tab_selesai"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="SELESAI"
                    android:backgroundTint="@android:color/white"
                    android:textColor="#4A6FA5"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tabungan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="12dp"
                android:paddingBottom="100dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB dinaikkan -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_tambah_tabungan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#2C3E6B"
        app:tint="@android:color/white"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="140dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>