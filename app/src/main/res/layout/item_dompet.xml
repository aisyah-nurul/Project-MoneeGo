<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDompet"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <!-- Stripe warna kiri sesuai jenis dompet -->
    <View
        android:id="@+id/viewJenisStripe"
        android:layout_width="5dp"
        android:layout_height="match_parent"
        android:background="#37474F" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Baris Atas: Icon + Nama/Jenis + Tanggal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Kontainer lingkaran icon -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp">

                <View
                    android:id="@+id/viewIconBg"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_circle_gray" />

                <ImageView
                    android:id="@+id/ivIkonDompet"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_wallet"
                    android:scaleType="fitCenter"
                    android:contentDescription="Ikon Dompet" />
            </FrameLayout>

            <!-- Nama + Jenis -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNamaDompet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BCA Tabungan"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A2B34"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvTipeDompet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rekening Bank"
                    android:textSize="11sp"
                    android:textColor="#78909C" />
            </LinearLayout>

            <!-- Tanggal relatif -->
            <TextView
                android:id="@+id/tvTanggalDompet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Baru ditambahkan"
                android:textSize="10sp"
                android:textColor="#90A4AE" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ECEFF1"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Saldo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TERCATAT"
                android:textSize="10sp"
                android:letterSpacing="0.08"
                android:textColor="#90A4AE" />

            <TextView
                android:id="@+id/tvSaldoDompet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A2B34"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>