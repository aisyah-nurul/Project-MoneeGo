<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="#CCCCCC" />

        <!-- Judul -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tambah Dompet Baru"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A2B34"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Label Nama -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Dompet"
            android:textSize="13sp"
            android:textColor="#546E7A"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilNamaDompet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#6B8FA3"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNamaDompet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contoh, BCA Tabungan"
                android:inputType="textCapWords"
                android:textSize="14sp"
                android:textColor="#1A2B34"
                android:textColorHint="#90A4AE" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label Jenis -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jenis Dompet"
            android:textSize="13sp"
            android:textColor="#546E7A"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Grid Jenis Dompet -->
        <GridLayout
            android:id="@+id/gridJenisDompet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="2"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/btnJenisBank"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_wallet_bank"
                    android:layout_marginBottom="4dp"
                    android:contentDescription="Rekening Bank" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rekening Bank"
                    android:textSize="10sp"
                    android:textColor="#1A2B34"
                    android:gravity="center"
                    android:maxLines="2" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnJenisDigital"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_wallet_digital"
                    android:layout_marginBottom="4dp"
                    android:contentDescription="Dompet Digital" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dompet Digital"
                    android:textSize="10sp"
                    android:textColor="#1A2B34"
                    android:gravity="center"
                    android:maxLines="2" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnJenisTunai"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_wallet_cash"
                    android:layout_marginBottom="4dp"
                    android:contentDescription="Uang Tunai" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uang Tunai"
                    android:textSize="10sp"
                    android:textColor="#1A2B34"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnJenisInvestasi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_wallet_investasi"
                    android:layout_marginBottom="4dp"
                    android:contentDescription="Investasi" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Investasi"
                    android:textSize="10sp"
                    android:textColor="#1A2B34"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnJenisTabungan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_wallet_tabungan"
                    android:layout_marginBottom="4dp"
                    android:contentDescription="Tabungan" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tabungan"
                    android:textSize="10sp"
                    android:textColor="#1A2B34"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnJenisLainnya"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_wallet_lainnya"
                    android:layout_marginBottom="4dp"
                    android:contentDescription="Lainnya" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lainnya"
                    android:textSize="10sp"
                    android:textColor="#1A2B34"
                    android:gravity="center" />
            </LinearLayout>

        </GridLayout>

        <!-- Label Saldo Awal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saldo Awal"
            android:textSize="13sp"
            android:textColor="#546E7A"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSaldoAwal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#6B8FA3"
            app:prefixText="Rp "
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSaldoAwal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0"
                android:inputType="numberDecimal"
                android:textSize="14sp"
                android:textColor="#1A2B34"
                android:textColorHint="#90A4AE" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Label Tanggal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tanggal Ditambahkan"
            android:textSize="13sp"
            android:textColor="#546E7A"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <!-- Tombol pilih tanggal — klik buka DatePicker -->
        <LinearLayout
            android:id="@+id/btnPilihTanggal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_outline_rounded"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_kalender"
                android:contentDescription="Kalender"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvTanggalDipilih"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pilih tanggal..."
                android:textSize="14sp"
                android:textColor="#90A4AE" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="Pilih" />
        </LinearLayout>

        <!-- Tombol Simpan -->
        <Button
            android:id="@+id/btnSimpanDompet"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Simpan"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="#2C3E6B" />

    </LinearLayout>
</ScrollView>