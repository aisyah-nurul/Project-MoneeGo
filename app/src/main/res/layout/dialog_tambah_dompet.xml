<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tambah Dompet Baru"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama Dompet"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_nama_dompet"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Contoh: BCA Tabungan"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input_rounded"
        android:inputType="text"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jenis Dompet"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_rekening_bank"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Rekening Bank"
            android:textSize="11sp"
            android:backgroundTint="#EEEEEE"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_dompet_digital"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Dompet Digital"
            android:textSize="11sp"
            android:backgroundTint="#EEEEEE"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_uang_tunai"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Uang Tunai"
            android:textSize="11sp"
            android:backgroundTint="#EEEEEE"
            android:textColor="#1A1A2E"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_investasi"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Investasi"
            android:textSize="11sp"
            android:backgroundTint="#EEEEEE"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_tabungan_jenis"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Tabungan"
            android:textSize="11sp"
            android:backgroundTint="#EEEEEE"
            android:textColor="#1A1A2E"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btn_lainnya"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Lainnya"
            android:textSize="11sp"
            android:backgroundTint="#EEEEEE"
            android:textColor="#1A1A2E"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saldo Awal"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_saldo_awal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Rp 0"
        android:textSize="14sp"
        android:paddingHorizontal="16dp"
        android:background="@drawable/bg_input_rounded"
        android:inputType="numberDecimal"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btn_simpan_dompet"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Simpan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:textColor="@android:color/white"/>

</LinearLayout>