<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#CCCCCC"/>

    <!-- Header: judul + tombol simpan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_tambah_hutang"
            android:textColor="#1A1A2E"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#2ECC71"
            android:text="@string/btn_simpan"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp">

            <!-- Nama -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/label_nama_hutang"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_nama_hutang"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Jenis Hutang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_jenis_hutang"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <!-- Baris 1: Kartu Kredit | Pinjaman Online | Cicilan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnKartuKredit"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/jenis_kartu_kredit"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/btnPinjol"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/jenis_pinjol"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/btnCicilan"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/jenis_cicilan"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- Baris 2: Pinjaman Bank | Pinjam ke Kerabat | Lainnya -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnPinjamanBank"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/jenis_pinjaman_bank"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/btnPinjamKeKerabat"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/jenis_pinjam_kerabat"
                    android:textColor="#555555"
                    android:textSize="10sp"/>

                <TextView
                    android:id="@+id/btnLainnya"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/jenis_lainnya"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- BUG 1 FIX: Jumlah Hutang                                   -->
            <!-- Sebelumnya: hint="Rp 0" di dalam EditText                  -->
            <!--   → menyebabkan teks "Rp 0" muncul sebagai label mengambang-->
            <!-- Sesudah: prefixText="Rp " di TextInputLayout               -->
            <!--   → prefix "Rp" selalu terlihat di kiri field (sama persis  -->
            <!--     dengan field Nominal Cicilan), hint hanya tampil saat   -->
            <!--     field kosong dan tidak ada angka "0" yang menggantung.  -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_jumlah_hutang"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:prefixText="Rp ">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etJumlah"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="0"
                    android:inputType="number"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Limit Kredit (hanya muncul saat kartu kredit) -->
            <!-- BUG 1 FIX juga diterapkan di sini agar konsisten -->
            <LinearLayout
                android:id="@+id/layoutLimitKredit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_limit_kredit"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:prefixText="Rp ">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLimitKredit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="0"
                        android:inputType="number"
                        android:textSize="14sp"/>

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Jatuh Tempo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_jatuh_tempo"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:endIconDrawable="@drawable/ic_hutang"
                app:endIconMode="custom">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etJatuhTempo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="dd/mm/yyyy"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>