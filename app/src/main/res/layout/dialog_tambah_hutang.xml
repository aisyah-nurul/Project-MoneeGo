<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#CCCCCC"/>

    <!-- Header: judul + tombol simpan -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="8dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tambah Hutang Baru"
            android:textColor="#1A1A2E"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnSimpan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#2ECC71"
            android:text="Simpan"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp">

            <!-- Nama -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nama/Keterangan"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNama"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contoh, Pinjam ke Jingga"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Jenis Hutang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Jenis Hutang"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <!-- Baris 1: Kartu Kredit | Pinjaman Online | Cicilan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnKartuKredit"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Kartu Kredit"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/btnPinjol"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Pinjaman Online"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/btnCicilan"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Cicilan"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- Baris 2: Pinjaman Bank | Pinjam ke Kerabat | Lainnya -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnPinjamanBank"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Pinjaman Bank"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

                <TextView
                    android:id="@+id/btnPinjamKeKerabat"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Pinjam ke Kerabat"
                    android:textColor="#555555"
                    android:textSize="10sp"/>

                <TextView
                    android:id="@+id/btnLainnya"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_jenis_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Lainnya"
                    android:textColor="#555555"
                    android:textSize="11sp"/>

            </LinearLayout>

            <!-- Jumlah -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Jumlah Hutang"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etJumlah"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Rp 0"
                    android:inputType="number"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Limit Kredit (hanya muncul saat kartu kredit) -->
            <LinearLayout
                android:id="@+id/layoutLimitKredit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Limit Kartu Kredit"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLimitKredit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Rp 0"
                        android:inputType="number"
                        android:textSize="14sp"/>

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Jatuh Tempo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Jatuh Tempo (Opsional)"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:endIconDrawable="@drawable/ic_hutang"
                app:endIconMode="custom">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etJatuhTempo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="dd/mm/yyyy"
                    android:textSize="14sp"/>

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>