<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#CCCCCC"/>

    <!-- Header: nama hutang + tombol hapus -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_detail_hutang"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvSheetNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama hutang"
                android:textColor="#888888"
                android:textSize="13sp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnHapusHutang"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="#E74C3C"
            android:text="@string/btn_hapus_hutang"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Box info: sisa, sudah dibayar, progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_rounded"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_sisa_hutang"
                        android:textColor="#534AB7"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvSheetSisa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp0"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_sudah_dibayar"
                        android:textColor="#534AB7"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvSheetSudahDibayar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp0"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/label_progress"
                        android:textColor="#534AB7"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvSheetPersen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressSheet"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#2ECC71"
                    android:progressBackgroundTint="#DDDDDD"/>
            </LinearLayout>

            <!-- Riwayat cicilan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_riwayat_cicilan"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRiwayatCicilan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"/>

            <!-- Form input cicilan -->
            <LinearLayout
                android:id="@+id/layoutFormCicilan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Nominal cicilan -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_nominal_cicilan"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNominalCicilan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Rp 0"
                        android:inputType="numberDecimal"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Tanggal bayar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_tanggal_bayar"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTanggalCicilan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="dd/mm/yyyy"
                        android:focusable="false"
                        android:clickable="true"
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Sumber Dana (ganti catatan) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sumber Dana"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- Header sumber dana — klik untuk expand/collapse -->
                <LinearLayout
                    android:id="@+id/llSumberDanaHeader"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_wallet"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:id="@+id/tvSumberDanaCicilan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pilih dompet"
                        android:textColor="#888888"
                        android:textSize="14sp"/>

                    <ImageView
                        android:id="@+id/ivChevronSumberDana"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_down"/>
                </LinearLayout>

                <!-- Daftar pilihan dompet (expand/collapse) -->
                <LinearLayout
                    android:id="@+id/llOpsiDompet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_input_rounded"
                    android:layout_marginTop="2dp"
                    android:visibility="gone"/>

                <!-- Catatan opsional -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_catatan_opsional"
                    android:textColor="#333333"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="6dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCatatanCicilan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Transfer BCA..."
                        android:textSize="14sp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSimpanCicilan"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:backgroundTint="#2ECC71"
                    android:text="@string/btn_simpan_cicilan"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>

                <Button
                    android:id="@+id/btnBatalCicilan"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:backgroundTint="@android:color/transparent"
                    android:text="@string/btn_batal"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:elevation="0dp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- Badge lunas -->
            <LinearLayout
                android:id="@+id/layoutLunas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="#EAF9F0"
                android:padding="14dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅"
                    android:textSize="18sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_hutang_lunas"
                    android:textColor="#27AE60"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>