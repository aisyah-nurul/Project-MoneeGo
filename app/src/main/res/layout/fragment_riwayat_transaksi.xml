<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EDE8DC">

    <!-- Header biru -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_riwayat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#4A6FA5"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_jenis_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengeluaran"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/tv_tanggal_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tv_jenis_filter"
            app:layout_constraintStart_toStartOf="parent"/>

        <ImageView
            android:id="@+id/btn_toggle_kalender"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_tanggal"
            android:tint="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/tv_tanggal_header"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/ll_legend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginEnd="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_toggle_kalender">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#4CAF50"/>
            <TextView
                android:id="@+id/tv_persen_masuk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Pemasukan 0%"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp"/>
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#F44336"/>
            <TextView
                android:id="@+id/tv_persen_keluar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" Pengeluaran 0%"
                android:textSize="11sp"
                android:textColor="@android:color/white"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_ratio"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:progress="50"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="#F44336"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_tanggal_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Kalender (hidden by default, muncul saat toggle diklik) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_kalender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardElevation="4dp">

        <CalendarView
            android:id="@+id/calendar_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:dateTextAppearance="@android:style/TextAppearance.Small"
            android:firstDayOfWeek="2"/>

    </androidx.cardview.widget.CardView>

    <!--
        KUNCI FIX SCROLL:
        layout_height="0dp" + layout_weight="1" = isi sisa ruang
        Ini yang memastikan RecyclerView bisa scroll
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_transaksi"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"/>

</LinearLayout>