<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:weightSum="1">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_riwayat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_header"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="54dp"
        android:paddingBottom="14dp">

        <!-- Legend: lingkaran + teks pemasukan | lingkaran + teks pengeluaran -->
        <LinearLayout
            android:id="@+id/ll_legend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Lingkaran hijau -->
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/ic_circle_green"/>

            <TextView
                android:id="@+id/tv_persen_masuk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_persen_masuk"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="12dp"/>

            <!-- Lingkaran merah -->
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/ic_circle_red"/>

            <TextView
                android:id="@+id/tv_persen_keluar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_persen_keluar"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

        <!-- Tombol kalender -->
        <ImageView
            android:id="@+id/btn_toggle_kalender"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_tanggal"
            app:tint="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Tombol mata -->
        <ImageView
            android:id="@+id/btn_toggle_mata"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_eye"
            app:tint="@android:color/white"
            android:layout_marginEnd="12dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_toggle_kalender"/>

        <!-- Progress bar rasio -->
        <ProgressBar
            android:id="@+id/progress_ratio"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:progress="50"
            android:progressTint="@color/income_green"
            android:progressBackgroundTint="#F44336"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/ll_legend"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Navigasi tanggal -->
        <LinearLayout
            android:id="@+id/ll_nav_tanggal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/progress_ratio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/btn_prev_tanggal"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_chevron_down"
                android:rotation="90"
                app:tint="@android:color/white"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tv_tanggal_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textSize="13sp"
                android:textColor="@android:color/white"
                android:gravity="center"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/btn_next_tanggal"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_chevron_down"
                android:rotation="270"
                app:tint="@android:color/white"
                android:padding="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Ringkasan: Pemasukan | Pengeluaran | Selisih -->
        <LinearLayout
            android:id="@+id/ll_total_harian"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/ll_nav_tanggal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_total_pemasukan"
                    android:textSize="10sp"
                    android:textColor="#CCFFFFFF"/>
                <TextView
                    android:id="@+id/tv_total_masuk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/income_green"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#55FFFFFF"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_total_pengeluaran"
                    android:textSize="10sp"
                    android:textColor="#CCFFFFFF"/>
                <TextView
                    android:id="@+id/tv_total_keluar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#F44336"/>
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#55FFFFFF"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_selisih"
                    android:textSize="10sp"
                    android:textColor="#CCFFFFFF"/>
                <TextView
                    android:id="@+id/tv_selisih_harian"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_hint"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- KALENDER (hidden by default) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_kalender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardElevation="4dp">

        <CalendarView
            android:id="@+id/calendar_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:dateTextAppearance="@android:style/TextAppearance.Small"
            android:firstDayOfWeek="2"/>

    </androidx.cardview.widget.CardView>

    <!-- AREA KONTEN: RV + Empty State dalam FrameLayout -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- RecyclerView transaksi -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_transaksi"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="8dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="true"
            android:scrollbars="vertical"
            android:overScrollMode="always"/>

        <!-- Empty State — style identik dengan HutangFragment -->
        <LinearLayout
            android:id="@+id/layout_empty_transaksi"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_hutang"
                app:tint="@color/text_secondary"
                android:alpha="1"
                android:contentDescription="@string/empty_transaksi"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/empty_transaksi"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

    </FrameLayout>

</LinearLayout>