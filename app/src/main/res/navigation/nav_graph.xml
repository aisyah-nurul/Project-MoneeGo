<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.appmoneego.ui.splash.SplashFragment"
        android:label="Splash">
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.appmoneego.ui.dashboard.DashboardFragment"
        android:label="Dashboard">
        <action
            android:id="@+id/action_dashboard_to_dompet"
            app:destination="@id/dompetFragment"/>
        <action
            android:id="@+id/action_dashboard_to_tabungan"
            app:destination="@id/tabunganFragment"/>
        <action
            android:id="@+id/action_dashboard_to_hutang"
            app:destination="@id/hutangFragment"/>
        <action
            android:id="@+id/action_dashboard_to_tambahTransaksi"
            app:destination="@id/tambahTransaksiFragment"/>
    </fragment>

    <fragment
        android:id="@+id/riwayatTransaksiFragment"
        android:name="com.example.appmoneego.ui.riwayattransaksi.RiwayatTransaksiFragment"
        android:label="Riwayat"/>

    <fragment
        android:id="@+id/dompetFragment"
        android:name="com.example.appmoneego.ui.dompet.DompetFragment"
        android:label="Dompet"/>

    <fragment
        android:id="@+id/tabunganFragment"
        android:name="com.example.appmoneego.ui.tabungan.TabunganFragment"
        android:label="Tabungan"/>

    <fragment
        android:id="@+id/hutangFragment"
        android:name="com.example.appmoneego.ui.hutang.HutangFragment"
        android:label="Hutang"/>

    <fragment
        android:id="@+id/analisisFragment"
        android:name="com.example.appmoneego.ui.analisis.AnalisisFragment"
        android:label="Analisis"/>

    <fragment
        android:id="@+id/pengaturanFragment"
        android:name="com.example.appmoneego.ui.pengaturan.PengaturanFragment"
        android:label="Pengaturan"/>

    <fragment
        android:id="@+id/tambahTransaksiFragment"
        android:name="com.example.appmoneego.ui.tambahtransaksi.TambahTransaksiFragment"
        android:label="Tambah Transaksi"/>

</navigation>